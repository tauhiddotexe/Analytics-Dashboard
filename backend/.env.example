# Transaction pooler (port 6543) — username must include project ref after the dot
DATABASE_URL=postgresql+psycopg://postgres.project-ref:password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
# Direct connection (port 5432) — plain postgres user
# DATABASE_URL=postgresql+psycopg://postgres:password@db.project-ref.supabase.co:5432/postgres?sslmode=require
ALLOWED_ORIGINS=http://localhost:5173
APP_ENV=development
